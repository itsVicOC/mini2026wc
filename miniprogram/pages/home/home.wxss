.progress-card {
  padding: 26rpx;
}

.progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-title-row {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.refresh-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  color: #0b7a3b;
  line-height: 1;
}

.refresh-icon {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.refresh-button.spinning .refresh-icon {
  animation: refresh-spin 0.8s linear infinite;
}

@keyframes refresh-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.progress-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #eaf5ee;
  color: #0b7a3b;
  font-size: 30rpx;
  font-weight: 900;
}

.progress-bar {
  height: 14rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e6eee8;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0b7a3b, #d7b15c);
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: #f6faf7;
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 900;
  color: #10391f;
}

.stat-value.live {
  color: #bc2d2d;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #748078;
}

.match-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
}

.match-card.tappable {
  border-color: rgba(215, 177, 92, 0.45);
  box-shadow: 0 10rpx 30rpx rgba(136, 99, 30, 0.12);
}

.match-card.tappable:active {
  transform: scale(0.992);
  opacity: 0.94;
}

.match-card.compact {
  padding: 18rpx 20rpx;
}

.match-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  color: #68756e;
}

.meta-time {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-actions {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 8rpx;
}

.detail-chip {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #fff3cf;
  color: #8a6315;
  font-size: 22rpx;
  font-weight: 800;
  white-space: nowrap;
}

.match-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx minmax(0, 1fr);
  align-items: center;
  gap: 12rpx;
}

.team {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 700;
}

.team text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team.right {
  justify-content: flex-end;
  text-align: right;
}

.team-link {
  color: #0b7a3b;
}

.team-link:active {
  opacity: 0.72;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-title {
  margin: 8rpx 0 14rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #244931;
}

.subscribe-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 56rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border: 0;
  border-radius: 8rpx;
  background: #0b7a3b;
  color: #fff;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  box-shadow: 0 8rpx 16rpx rgba(8, 98, 53, 0.18);
}

.subscribe-button:active {
  opacity: 0.84;
}

.subscribe-button.subscribed {
  background: #eaf5ee;
  color: #0b7a3b;
  box-shadow: none;
}

.subscribe-button.loading {
  opacity: 0.74;
}
