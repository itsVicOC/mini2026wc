.progress-card {
  padding: 26rpx;
}

.progress-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-title-row {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.refresh-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  color: #0b7a3b;
  line-height: 1;
}

.refresh-icon {
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1;
}

.refresh-button.spinning .refresh-icon {
  animation: refresh-spin 0.8s linear infinite;
}

@keyframes refresh-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.progress-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #eaf5ee;
  color: #0b7a3b;
  font-size: 30rpx;
  font-weight: 900;
}

.progress-bar {
  height: 14rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e6eee8;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #0b7a3b, #d7b15c);
}

.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: #f6faf7;
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 900;
  color: #10391f;
}

.stat-value.live {
  color: #bc2d2d;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #748078;
}

.match-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
}

.match-card.compact {
  padding: 18rpx 20rpx;
}

.match-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 24rpx;
  color: #68756e;
}

.match-row {
  display: grid;
  grid-template-columns: 1fr 130rpx 1fr;
  align-items: center;
  gap: 12rpx;
}

.team {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  font-size: 27rpx;
  font-weight: 700;
}

.team text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team.right {
  justify-content: flex-end;
  text-align: right;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-title {
  margin: 8rpx 0 14rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #244931;
}

.match-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.subscribe-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 188rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #0b7a3b;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.subscribe-button.subscribed {
  background: #eaf5ee;
  color: #0b7a3b;
}

.subscribe-button.loading {
  opacity: 0.72;
}
