.team-detail-page {
  padding-bottom: 64rpx;
}

.team-hero {
  display: grid;
  grid-template-columns: 108rpx 1fr;
  gap: 22rpx;
  align-items: center;
  padding: 30rpx 26rpx;
  border-radius: 18rpx;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(8, 66, 35, 0.98), rgba(12, 122, 60, 0.94)),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 2rpx, transparent 2rpx 86rpx);
}

.hero-crest {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.team-hero-main {
  min-width: 0;
}

.team-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 42rpx;
  font-weight: 900;
}

.team-subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.82);
}

.team-summary {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.74);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.stat-card {
  padding: 18rpx 8rpx;
  text-align: center;
}

.stat-value {
  color: #0b7a3b;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 4rpx;
  color: #748078;
  font-size: 22rpx;
}

.panel {
  padding: 24rpx;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #143a22;
}

.panel-meta {
  color: #7c887f;
  font-size: 23rpx;
}

.info-row,
.form-row {
  display: grid;
  grid-template-columns: 180rpx 1fr;
  gap: 16rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(20, 80, 43, 0.08);
  font-size: 26rpx;
}

.info-row:first-of-type {
  border-top: 0;
}

.info-label {
  color: #77847c;
}

.info-value {
  text-align: right;
  color: #15251a;
  font-weight: 800;
}

.form-list {
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #edf2ef;
  color: #5d6962;
  font-size: 22rpx;
  font-weight: 900;
}

.form-pill.win {
  background: #dff3e7;
  color: #0b7a3b;
}

.form-pill.draw {
  background: #f4ecd7;
  color: #8a6315;
}

.form-pill.lose {
  background: #f7e5e3;
  color: #bd3c2f;
}

.mini-empty {
  padding: 26rpx 0 12rpx;
  text-align: center;
  color: #839087;
  font-size: 25rpx;
}

.match-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 16rpx;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(20, 80, 43, 0.08);
}

.match-item.tappable:active {
  opacity: 0.76;
}

.match-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.opponent-crest {
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #edf2ef;
}

.match-main {
  min-width: 0;
}

.opponent-name,
.scorer-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #15251a;
  font-size: 26rpx;
  font-weight: 800;
}

.match-sub {
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #7d8981;
  font-size: 22rpx;
}

.match-result {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.result {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  font-size: 21rpx;
  font-weight: 900;
}

.result.win {
  background: #dff3e7;
  color: #0b7a3b;
}

.result.draw {
  background: #f4ecd7;
  color: #8a6315;
}

.result.lose {
  background: #f7e5e3;
  color: #bd3c2f;
}

.match-score {
  color: #102718;
  font-size: 27rpx;
  font-weight: 900;
}

.match-status {
  justify-self: end;
  color: #0b7a3b;
  font-size: 23rpx;
  font-weight: 800;
}

.subscribe-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 54rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #0b7a3b;
  color: #fff;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
  box-shadow: 0 8rpx 16rpx rgba(8, 98, 53, 0.18);
}

.subscribe-button:active {
  opacity: 0.84;
}

.subscribe-button.subscribed {
  background: #eaf5ee;
  color: #0b7a3b;
  box-shadow: none;
}

.subscribe-button.loading {
  opacity: 0.74;
}

.scorer-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 160rpx;
  gap: 12rpx;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(20, 80, 43, 0.08);
}

.scorer-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  color: #657169;
  font-size: 22rpx;
}
