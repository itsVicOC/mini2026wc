.small-hero .hero-title {
  font-size: 40rpx;
}

.scorer-list {
  margin-top: 24rpx;
  overflow: hidden;
}

.scorer-row {
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 90rpx 90rpx;
  align-items: center;
  min-height: 104rpx;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #eef2ef;
}

.scorer-row:last-child {
  border-bottom: 0;
}

.rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #edf2ef;
  color: #244931;
  font-weight: 900;
}

.rank.top {
  background: #f4e5bd;
  color: #8a5a00;
}

.player {
  min-width: 0;
}

.player-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 800;
}

.player-team {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
  overflow: hidden;
  font-size: 23rpx;
}

.player-team text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-link {
  color: #0b7a3b;
}

.team-link:active {
  opacity: 0.72;
}

.team-flag {
  flex: 0 0 auto;
  width: 34rpx;
  height: 24rpx;
  padding: 3rpx;
  border: 1rpx solid rgba(23, 61, 36, 0.12);
  border-radius: 6rpx;
  background: #f7faf8;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.75);
}

.goal-box,
.assist-box {
  text-align: center;
}

.goal-value {
  color: #0b7a3b;
  font-size: 34rpx;
  font-weight: 900;
}

.assist-value {
  color: #27342d;
  font-size: 30rpx;
  font-weight: 800;
}

.goal-label {
  margin-top: 2rpx;
  color: #77837c;
  font-size: 20rpx;
}
