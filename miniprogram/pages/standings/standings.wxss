.small-hero .hero-title {
  font-size: 40rpx;
}

.group-scroll {
  margin: 24rpx 0 18rpx;
  white-space: nowrap;
}

.groups {
  display: flex;
  gap: 10rpx;
}

.group-tab {
  flex: 0 0 auto;
  min-width: 88rpx;
  padding: 14rpx 10rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #4d5b52;
  text-align: center;
  font-size: 25rpx;
  border: 1rpx solid rgba(17, 86, 45, 0.1);
}

.group-tab.active {
  background: #0b7a3b;
  color: #fff;
}

.table {
  overflow: hidden;
}

.table-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 54rpx 54rpx 54rpx 54rpx 60rpx 60rpx;
  align-items: center;
  min-height: 82rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #eef2ef;
  font-size: 24rpx;
}

.table-row:last-child {
  border-bottom: 0;
}

.table-head {
  min-height: 70rpx;
  background: #f3f8f4;
  color: #66736b;
  font-size: 22rpx;
  font-weight: 700;
}

.rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #edf2ef;
  font-weight: 800;
}

.rank.qualified {
  background: #dff3e7;
  color: #0b7a3b;
}

.team-cell {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  font-weight: 700;
}

.team-cell.tappable {
  color: #0b7a3b;
}

.team-cell.tappable:active {
  opacity: 0.72;
}

.team-cell text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.team-arrow {
  flex: 0 0 auto;
  color: #d0a955;
  font-size: 30rpx;
  font-weight: 900;
}

.points {
  color: #0b7a3b;
  font-weight: 900;
}
